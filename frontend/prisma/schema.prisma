generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  // NO URL LINE HERE. It must be empty for Prisma 7.
}

// ... keep all your models (agent_profiles, properties, etc.) exactly as they are below this

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model agent_profiles {
  user_id             String    @id @db.Uuid
  license_number      String    @unique @db.VarChar(100)
  agency_name         String?   @db.VarChar(255)
  bio                 String?
  years_of_experience Int?      @db.SmallInt
  social_website      String?   @db.VarChar(255)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  users               users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model amenities {
  id                 Int                  @id @db.SmallInt
  name               String               @unique @db.VarChar(100)
  property_amenities property_amenities[]
}

model properties {
  id                     String             @id(map: "properties_pkey1") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                  String             @db.VarChar(255)
  description            String
  location               String             @db.VarChar(255)
  address                String?            @db.VarChar(255)
  bedrooms               Int?               @db.SmallInt
  bathrooms              Int?               @db.SmallInt
  square_footage         Int?
  parking_details        String?            @db.VarChar(255)
  amenities              Json?
  year_built             Int?               @db.SmallInt
  neighbourhood_insights String?
  status                 String?            @default("pending") @db.VarChar(50)
  property_type_id       Int?               @db.SmallInt
  transaction_type_id    Int?               @db.SmallInt
  created_by             String?            @db.Uuid
  images                 String[]
  videos                 String[]
  created_at             DateTime?          @default(now()) @db.Timestamp(6)
  updated_at             DateTime?          @default(now()) @db.Timestamp(6)
  deleted_at             DateTime?          @db.Timestamp(6)
  users                  users?             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  property_types         property_types?    @relation(fields: [property_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "properties_property_type_id_fkey1")
  transaction_types      transaction_types? @relation(fields: [transaction_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "properties_transaction_type_id_fkey1")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model properties_old {
  id                  String               @id(map: "properties_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  owner_id            String               @db.Uuid
  title               String               @db.VarChar(255)
  description         String?
  property_type_id    Int                  @db.SmallInt
  transaction_type_id Int                  @db.SmallInt
  price               Decimal              @db.Decimal(15, 2)
  bedrooms            Int?                 @db.SmallInt
  bathrooms           Int?                 @db.SmallInt
  area_sqm            Decimal?             @db.Decimal(10, 2)
  country             String               @db.VarChar(100)
  city                String               @db.VarChar(100)
  address             String?
  is_published        Boolean?             @default(false)
  is_approved         Boolean?             @default(false)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)
  users               users                @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "properties_owner_id_fkey")
  property_types      property_types       @relation(fields: [property_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "properties_property_type_id_fkey")
  transaction_types   transaction_types    @relation(fields: [transaction_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "properties_transaction_type_id_fkey")
  property_amenities  property_amenities[]
  property_media      property_media[]

  @@index([city], map: "idx_properties_city")
  @@index([owner_id], map: "idx_properties_owner_id")
  @@index([price], map: "idx_properties_price")
  @@index([property_type_id], map: "idx_properties_property_type")
  @@index([transaction_type_id], map: "idx_properties_transaction_type")
  @@index([is_published, is_approved], map: "idx_properties_visibility")
}

model property_amenities {
  property_id    String         @db.Uuid
  amenity_id     Int            @db.SmallInt
  amenities      amenities      @relation(fields: [amenity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties_old properties_old @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([property_id, amenity_id])
  @@index([amenity_id], map: "idx_property_amenities_amenity")
  @@index([property_id], map: "idx_property_amenities_property")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model property_media {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  property_id    String         @db.Uuid
  media_url      String
  media_type     String         @db.VarChar(20)
  display_order  Int?           @default(0) @db.SmallInt
  created_at     DateTime?      @default(now()) @db.Timestamp(6)
  properties_old properties_old @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([property_id], map: "idx_property_media_property_id")
}

model property_types {
  id             Int              @id @db.SmallInt
  name           String           @unique @db.VarChar(50)
  slug           String?          @unique @db.VarChar(50)
  properties     properties[]
  properties_old properties_old[]
}

model roles {
  id    Int     @id @db.SmallInt
  name  String  @unique @db.VarChar(50)
  users users[]
}

model transaction_types {
  id             Int              @id @db.SmallInt
  name           String           @unique @db.VarChar(50)
  slug           String?          @unique @db.VarChar(50)
  properties     properties[]
  properties_old properties_old[]
}

model users {
  id                    String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  first_name            String           @db.VarChar(50)
  last_name             String           @db.VarChar(50)
  email                 String           @unique @db.VarChar(255)
  phone_number          String?          @unique @db.VarChar(20)
  password_hash         String           @db.VarChar(255)
  role                  Int              @db.SmallInt
  is_verified           Boolean?         @default(false)
  is_active             Boolean?         @default(true)
  last_login_at         DateTime?        @db.Timestamp(6)
  failed_login_attempts Int?             @default(0) @db.SmallInt
  account_locked_until  DateTime?        @db.Timestamp(6)
  profile_image_url     String?          @db.VarChar(255)
  created_at            DateTime?        @default(now()) @db.Timestamp(6)
  updated_at            DateTime?        @default(now()) @db.Timestamp(6)
  agent_profiles        agent_profiles?
  properties            properties[]
  properties_old        properties_old[]
  roles                 roles            @relation(fields: [role], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
